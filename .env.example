# ─────────────────────────────────────────────────────────────
# Eclipse Motors environment variables
# Copy this file to `.env.local` (dev) or set them in the server env.
# ─────────────────────────────────────────────────────────────

# ── Public (safe to expose in the browser bundle) ────────────
# The dealer's WhatsApp number, digits only (country code + number,
# no "+", spaces or dashes). Example for Ghana: 233201234567
NEXT_PUBLIC_WHATSAPP_NUMBER=233201234567

# Public dealership name shown across the site.
NEXT_PUBLIC_DEALER_NAME=Eclipse Motors

# GHS -> USD conversion rate used by the currency toggle.
NEXT_PUBLIC_GHS_PER_USD=15.5

# ── Backend (SERVER ONLY — never NEXT_PUBLIC, never commit real values) ──
# PostgreSQL connection string. For local dev with docker-compose:
DATABASE_URL=postgres://eclipse:eclipse@localhost:5432/eclipse

# Long random string used to sign the admin session cookie.
# Generate one with: openssl rand -base64 48
SESSION_SECRET=change-me-to-a-long-random-string

# Bootstrap admin account, created on the first `npm run db:migrate`
# if no admin exists yet. Change the password immediately in real use.
ADMIN_EMAIL=you@eclipsemotors.org
ADMIN_PASSWORD=change-me

# Directory where uploaded car photos are written. Leave blank in dev
# (defaults to ./public/uploads). In production set an absolute path
# outside the repo, e.g. /var/www/eclipse-uploads
UPLOAD_DIR=
