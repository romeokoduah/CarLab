# ─────────────────────────────────────────────────────────────
# Eclipse Motors environment variables
# Copy this file to `.env.local` and fill in the values.
# The app ships with sensible defaults and local seed data, so it
# runs out of the box even if you leave these unset.
# ─────────────────────────────────────────────────────────────

# The dealer's WhatsApp number in full international format, digits only
# (country code + number, no "+", spaces or dashes).
# Example for Ghana: 233201234567
NEXT_PUBLIC_WHATSAPP_NUMBER=233201234567

# Public dealership name shown across the site.
NEXT_PUBLIC_DEALER_NAME=Eclipse Motors

# GHS -> USD conversion rate used by the currency toggle.
# (1 USD = this many GHS). Update as the rate moves.
NEXT_PUBLIC_GHS_PER_USD=15.5

# ── Optional: Supabase backend ───────────────────────────────
# The data layer lives behind lib/api.ts and defaults to bundled
# seed data + localStorage. To swap in Supabase (Postgres + Storage
# + Auth), provide these and implement the Supabase adapter.
# NEXT_PUBLIC_SUPABASE_URL=
# NEXT_PUBLIC_SUPABASE_ANON_KEY=

# ── Admin client login (optional) ────────────────────────────
# Leave BOTH blank in production: the /admin route is protected at
# the server (nginx Basic Auth), and NEXT_PUBLIC_* values are visible
# in the browser bundle, so never put a real secret here. These only
# enable the in-app client login gate for local development.
NEXT_PUBLIC_ADMIN_EMAIL=
NEXT_PUBLIC_ADMIN_PASSWORD=
